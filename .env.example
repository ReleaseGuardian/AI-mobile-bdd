# Copy this file to .env and fill in real values. Never commit .env.

# ===== Environment & platform selection =====
TEST_ENV=staging
PLATFORM=android
EXECUTION_TARGET=local

# ===== BrowserStack credentials (get these from https://www.browserstack.com/accounts/settings) =====
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
# Set to true only if the app-under-test needs to reach an internal/staging network
# via BrowserStack Local binary.
BROWSERSTACK_LOCAL=false

# ===== BrowserStack app IDs =====
# Obtained by uploading your .apk/.ipa via the BrowserStack App Automate REST API:
#   curl -u "$BROWSERSTACK_USERNAME:$BROWSERSTACK_ACCESS_KEY" \
#     -X POST "https://api-cloud.browserstack.com/app-automate/upload" \
#     -F "file=@/path/to/app.apk"
# The response's "app_url" (bs://<hash>) goes here.
BROWSERSTACK_ANDROID_APP_ID=
BROWSERSTACK_IOS_APP_ID=

# ===== BrowserStack device targeting =====
BROWSERSTACK_ANDROID_DEVICE=Google Pixel 7
BROWSERSTACK_ANDROID_OS_VERSION=13.0
BROWSERSTACK_IOS_DEVICE=iPhone 14
BROWSERSTACK_IOS_OS_VERSION=16

# ===== Local emulator/simulator app paths (used when EXECUTION_TARGET=local) =====
ANDROID_APP_PATH=./apps/android/BStackSampleApp.apk
ANDROID_DEVICE_NAME=Android Emulator
ANDROID_PLATFORM_VERSION=13.0

IOS_APP_PATH=./apps/ios/BStackSampleApp.ipa
IOS_DEVICE_NAME=iPhone 14 Simulator
IOS_PLATFORM_VERSION=16.0

# ===== Execution tuning =====
MAX_INSTANCES=1
LOG_LEVEL=info
DEFAULT_TIMEOUT=15000
TEST_RETRY_COUNT=1
# Cucumber tag expression, e.g. "@smoke and not @wip"
TEST_TAGS=
