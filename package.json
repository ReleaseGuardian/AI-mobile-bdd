{
  "name": "mobile-bdd-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade mobile BDD automation framework (Gherkin + TypeScript + Appium + WebdriverIO + BrowserStack)",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test:android": "cross-env EXECUTION_TARGET=local wdio run ./config/wdio.android.local.conf.ts",
    "test:ios": "cross-env EXECUTION_TARGET=local wdio run ./config/wdio.ios.local.conf.ts",
    "test:android:browserstack": "cross-env EXECUTION_TARGET=browserstack wdio run ./config/wdio.android.browserstack.conf.ts",
    "test:ios:browserstack": "cross-env EXECUTION_TARGET=browserstack wdio run ./config/wdio.ios.browserstack.conf.ts",
    "test:staging:android:browserstack": "cross-env TEST_ENV=staging npm run test:android:browserstack",
    "test:staging:ios:browserstack": "cross-env TEST_ENV=staging npm run test:ios:browserstack",
    "test:prod:android:browserstack": "cross-env TEST_ENV=prod npm run test:android:browserstack",
    "test:prod:ios:browserstack": "cross-env TEST_ENV=prod npm run test:ios:browserstack",
    "test:local": "npm run test:android",
    "test:browserstack": "npm run test:android:browserstack",
    "report:generate": "ts-node config/report-generator.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.0",
    "@wdio/appium-service": "^8.39.0",
    "@wdio/browserstack-service": "^8.39.0",
    "@wdio/cli": "^8.39.0",
    "@wdio/cucumber-framework": "^8.39.0",
    "@wdio/globals": "^8.39.0",
    "@wdio/local-runner": "^8.39.0",
    "@wdio/spec-reporter": "^8.39.0",
    "@wdio/types": "^8.39.0",
    "appium": "^2.11.0",
    "cross-env": "^7.0.3",
    "deepmerge": "^4.3.1",
    "dotenv": "^16.4.5",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "multiple-cucumber-html-reporter": "^3.7.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "winston": "^3.13.1"
  }
}
